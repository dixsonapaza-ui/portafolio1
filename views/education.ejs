<%- include('partials/head') %>

<!-- Page Hero -->
<section class="relative pt-28 pb-16 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <div class="orb w-96 h-96 -top-20 -right-20 bg-brand/25"></div>
    <div class="orb w-64 h-64 bottom-0 -left-10 bg-cyan/15" style="animation-delay:-3s"></div>
  </div>
  <div class="relative z-10 max-w-6xl mx-auto px-6 text-center reveal">
    <span class="inline-block px-4 py-1 rounded-full text-xs font-semibold text-brand bg-brand/10 border border-brand/25 tracking-wide mb-4"><i class="fas fa-graduation-cap mr-1"></i> Formación</span>
    <h1 class="text-5xl font-black mb-3">Mi <span class="text-gradient">Educación</span></h1>
    <p class="text-gray-400 text-lg">Formación académica y técnica que sustenta mi desarrollo profesional</p>
  </div>
</section>

<section class="py-16">
  <div class="max-w-4xl mx-auto px-6">

    <% education.forEach(edu=>{ %>
    <div class="reveal flex gap-6 p-8 bg-dark-700 border border-white/[0.06] rounded-3xl hover:border-brand/30 hover:shadow-glow transition-all mb-8">
      <div class="flex flex-col items-center shrink-0">
        <div class="w-16 h-16 flex items-center justify-center text-2xl bg-brand/10 border border-brand/25 rounded-xl text-white"><i class="<%= edu.icon %>"></i></div>
        <div class="w-0.5 flex-1 bg-gradient-to-b from-brand to-transparent mt-3 min-h-[40px]"></div>
      </div>
      <div class="flex-1">
        <div class="flex justify-between items-start flex-wrap gap-3 mb-3">
          <div>
            <span class="inline-flex items-center gap-1.5 text-xs font-bold px-3 py-1 rounded-full <%= edu.status==='En curso' ? 'bg-green-500/10 text-green-400 border border-green-500/25' : 'bg-gray-500/10 text-gray-400 border border-gray-500/25' %> mb-2">
              <span class="w-1.5 h-1.5 rounded-full bg-current <%= edu.status==='En curso' ? 'pulse-dot' : '' %>"></span>
              <%= edu.status %>
            </span>
            <h2 class="text-2xl font-black mb-1"><%= edu.degree %></h2>
            <p class="text-gray-400 text-sm"><i class="fas fa-university mr-2 text-brand"></i><strong class="text-gray-200"><%= edu.institution %></strong> — <%= edu.location %></p>
          </div>
          <span class="text-sm text-gray-500 shrink-0"><i class="fas fa-calendar-alt mr-1.5"></i><%= edu.period %></span>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed mb-4"><%= edu.description %></p>
        <div class="flex flex-wrap gap-2">
          <% edu.highlights.forEach(h=>{ %>
          <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-full bg-cyan/10 text-cyan border border-cyan/25"><i class="fas fa-check text-[10px]"></i><%= h %></span>
          <% }) %>
        </div>
      </div>
    </div>
    <% }) %>

    <!-- Self-learning -->
    <div class="text-center mb-10 reveal mt-12">
      <span class="inline-block px-4 py-1 rounded-full text-xs font-semibold text-brand bg-brand/10 border border-brand/25 tracking-wide mb-3"><i class="fas fa-handshake mr-1"></i> Auto-aprendizaje</span>
      <h2 class="text-3xl font-black">Aprendizaje <span class="text-gradient">Continuo</span></h2>
      <p class="text-gray-400 mt-2">Más allá del aula, sigo formándome constantemente</p>
    </div>
    <div class="reveal grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <% [['fas fa-laptop-code','Proyectos Reales','Aprendizaje práctico construyendo e-commerce y landing pages con tecnologías modernas.'],['fas fa-book','Documentación Oficial','Consulta constante de docs de Django, Express, y buenas prácticas REST.'],['fas fa-robot','IA como Mentor','Uso estratégico de Claude y Antigravity para aprender patrones y optimizar código.'],['fas fa-cloud-upload-alt','Cloud Deploy','Experiencia práctica desplegando en Render y Vercel con arquitecturas desacopladas.']].forEach(([icon,title,desc])=>{ %>
      <div class="p-5 bg-dark-700 border border-white/[0.06] rounded-2xl text-center hover:border-brand/30 hover:-translate-y-1.5 hover:shadow-glow transition-all">
        <div class="text-2xl text-white mb-3 flex justify-center"><i class="<%= icon %>"></i></div>
        <h3 class="font-bold text-sm mb-2"><%= title %></h3>
        <p class="text-xs text-gray-400 leading-relaxed"><%= desc %></p>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<%- include('partials/foot') %>
