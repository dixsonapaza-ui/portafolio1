<%- include('partials/head') %>

<!-- Page Hero -->
<section class="relative pt-28 pb-16 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <div class="orb w-96 h-96 -top-20 -right-20 bg-brand/25"></div>
    <div class="orb w-64 h-64 bottom-0 -left-10 bg-cyan/15" style="animation-delay:-3s"></div>
  </div>
  <div class="relative z-10 max-w-6xl mx-auto px-6 text-center reveal">
    <span class="inline-block px-4 py-1 rounded-full text-xs font-semibold text-brand bg-brand/10 border border-brand/25 tracking-wide mb-4">💼 Trayectoria</span>
    <h1 class="text-5xl font-black mb-3">Experiencia <span class="text-gradient">Laboral</span></h1>
    <p class="text-gray-400 text-lg">Mi recorrido profesional y las experiencias que me han formado</p>
  </div>
</section>

<!-- Timeline -->
<section class="py-16">
  <div class="max-w-3xl mx-auto px-6">
    <div class="timeline">

      <% experience.forEach((exp, i) => { %>
      <div class="tl-item reveal <%= i%2===0?'tl-left':'tl-right' %>">
        <div class="tl-dot"><%= exp.icon %></div>
        <div class="p-5 bg-dark-700 border border-white/[0.06] rounded-2xl hover:border-brand/30 hover:-translate-y-0.5 hover:shadow-glow transition-all">
          <div class="flex items-center justify-between gap-2 mb-2 flex-wrap">
            <span class="text-xs font-bold px-3 py-1 rounded-full bg-brand/10 text-brand border border-brand/25"><%= exp.period %></span>
            <span class="text-xs text-gray-500"><i class="fas fa-building mr-1"></i><%= exp.type %></span>
          </div>
          <h3 class="font-bold text-base mb-1"><%= exp.role %></h3>
          <p class="text-sm text-gray-400 mb-3"><i class="fas fa-map-marker-alt mr-1 text-pink"></i><strong class="text-gray-300"><%= exp.company %></strong> — <%= exp.location %></p>
          <ul class="flex flex-col gap-1.5">
            <% exp.bullets.forEach(b=>{ %>
            <li class="flex items-start gap-2 text-xs text-gray-400"><i class="fas fa-chevron-right text-brand mt-0.5 shrink-0 text-[10px]"></i><%= b %></li>
            <% }) %>
          </ul>
        </div>
      </div>
      <% }) %>

      <!-- Current status -->
      <div class="tl-item reveal tl-left">
        <div class="tl-dot tl-dot-active">🚀</div>
        <div class="p-5 bg-dark-700 border border-green-500/25 rounded-2xl hover:-translate-y-0.5 transition-all">
          <div class="flex items-center justify-between gap-2 mb-2 flex-wrap">
            <span class="text-xs font-bold px-3 py-1 rounded-full bg-green-500/10 text-green-400 border border-green-500/25">2025 – Presente</span>
            <span class="text-xs text-gray-500"><i class="fas fa-star mr-1 text-yellow-400"></i>Activo</span>
          </div>
          <h3 class="font-bold text-base mb-1">Backend Developer Jr (Búsqueda activa)</h3>
          <p class="text-sm text-gray-400 mb-3"><i class="fas fa-map-marker-alt mr-1 text-pink"></i><strong class="text-gray-300">Arequipa, Perú</strong> — Remoto / Presencial</p>
          <ul class="flex flex-col gap-1.5">
            <% [['Desarrollo de proyectos personales con Django y Node.js'],['Implementación de arquitecturas cliente-servidor cloud'],['Formación continua en TECSUP (2024–2026)']].forEach(([b])=>{ %>
            <li class="flex items-start gap-2 text-xs text-gray-400"><i class="fas fa-chevron-right text-green-400 mt-0.5 shrink-0 text-[10px]"></i><%= b %></li>
            <% }) %>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-16">
  <div class="max-w-6xl mx-auto px-6">
    <div class="reveal relative overflow-hidden bg-dark-700 border border-white/[0.06] rounded-3xl p-12 text-center">
      <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
        <div class="w-80 h-80 rounded-full bg-brand/10 blur-3xl"></div>
      </div>
      <h2 class="relative text-3xl font-black mb-3">¿Trabajamos juntos?</h2>
      <p class="relative text-gray-400 mb-8">Estoy en búsqueda activa de nuevas oportunidades donde pueda crecer y aportar valor real.</p>
      <div class="relative flex flex-wrap gap-3 justify-center">
        <a href="/contactame" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-white bg-gradient-hero hover:shadow-glow hover:-translate-y-0.5 transition-all"><i class="fas fa-envelope"></i> Contactarme</a>
        <a href="/habilidades" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-brand border border-brand hover:bg-brand hover:text-white transition-all"><i class="fas fa-code"></i> Ver habilidades</a>
      </div>
    </div>
  </div>
</section>

<%- include('partials/foot') %>
