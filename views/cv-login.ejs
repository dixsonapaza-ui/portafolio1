<%- include('partials/head') %>

<section style="min-height: calc(100vh - 120px); display: flex; align-items: center; justify-content: center; padding: 140px 24px 100px; background: var(--bg-primary);">
  <div style="max-width: 440px; width: 100%; background: var(--bg-secondary); border: 1px solid rgba(255, 255, 255, 0.06); padding: 48px 40px; border-radius: 20px; box-shadow: var(--shadow-premium);">
    
    <div style="text-align: center; margin-bottom: 32px;">
      <span style="font-family: var(--font-mono); font-size: 11px; color: var(--accent-1); letter-spacing: 0.2em; text-transform: uppercase; display: block; margin-bottom: 8px;">Área Privada</span>
      <h1 class="fr-display" style="font-size: 32px; color: #fff; margin: 0; font-style: italic;">Gestor de CVs</h1>
      <p style="font-family: var(--font-body); font-size: 14px; color: var(--text-muted); margin-top: 10px;">Ingresa la contraseña para acceder al panel de administración.</p>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div style="background: rgba(232, 98, 26, 0.1); border: 1px solid rgba(232, 98, 26, 0.25); color: #fff; padding: 12px 16px; border-radius: 8px; font-size: 13px; margin-bottom: 24px; font-family: var(--font-body); display: flex; align-items: center; gap: 8px;">
        <i class="fas fa-exclamation-circle" style="color: var(--accent-1);"></i>
        <span><%= error %></span>
      </div>
    <% } %>

    <form action="/dixson-cv-manager/login" method="POST">
      <div style="margin-bottom: 24px;">
        <label for="password" style="display: block; font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-muted); margin-bottom: 8px;">Contraseña</label>
        <input type="password" id="password" name="password" required placeholder="••••••••" style="width: 100%; padding: 14px 18px; background: var(--bg-primary); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 10px; color: #fff; font-family: var(--font-body); font-size: 15px; outline: none; transition: border-color 0.3s;">
      </div>

      <button type="submit" class="footer-cta-btn" style="width: 100%; border: none; cursor: pointer; justify-content: center; font-size: 13px;">
        <i class="fas fa-sign-in-alt"></i> Ingresar al Panel
      </button>
    </form>
    
    <div style="text-align: center; margin-top: 24px;">
      <a href="/" style="font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); text-decoration: none; text-transform: uppercase; letter-spacing: 0.05em; transition: color 0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='var(--text-muted)'">← Volver al Inicio</a>
    </div>

  </div>
</section>

<%- include('partials/foot') %>
