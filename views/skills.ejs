<%- include('partials/head') %>

<!-- Page Hero -->
<section class="relative pt-28 pb-16 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <div class="orb w-96 h-96 -top-20 -right-20 bg-brand/25"></div>
    <div class="orb w-64 h-64 bottom-0 -left-10 bg-cyan/15" style="animation-delay:-3s"></div>
  </div>
  <div class="relative z-10 max-w-6xl mx-auto px-6 text-center reveal">
    <span class="inline-block px-4 py-1 rounded-full text-xs font-semibold text-brand bg-brand/10 border border-brand/25 tracking-wide mb-4">⚙️ Stack Técnico</span>
    <h1 class="text-5xl font-black mb-3">Mis <span class="text-gradient">Habilidades</span></h1>
    <p class="text-gray-400 text-lg">Tecnologías y herramientas que domino para construir soluciones robustas</p>
  </div>
</section>

<section class="py-16">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Level header -->
    <div class="text-center mb-10 reveal">
      <span class="inline-block px-4 py-1 rounded-full text-xs font-semibold text-brand bg-brand/10 border border-brand/25 tracking-wide mb-3">📊 Nivel de Proficiencia</span>
      <h2 class="text-3xl font-black">Dominio <span class="text-gradient">Técnico</span></h2>
    </div>

    <!-- Legend -->
    <div class="reveal flex flex-wrap justify-center gap-4 mb-10 text-sm">
      <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-green-500/10 text-green-400 border border-green-500/25 font-semibold">● Avanzado</span>
      <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-brand/10 text-brand border border-brand/25 font-semibold">● Medio</span>
      <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-orange-500/10 text-orange-400 border border-orange-500/25 font-semibold">● Básico</span>
    </div>

    <!-- Skill Level Grid -->
    <div class="reveal grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-20">
      <%
        const cols = [
          { title: 'Lenguajes', icon: 'fas fa-code', items: skills.languages },
          { title: 'Backend',   icon: 'fas fa-server', items: skills.backend },
          { title: 'BD & Herramientas', icon: 'fas fa-database', items: [...skills.databases, ...skills.tools] }
        ];
        cols.forEach(col => {
      %>
      <div class="p-6 bg-dark-700 border border-white/[0.06] rounded-2xl hover:border-brand/30 transition-colors">
        <h3 class="flex items-center gap-2 font-bold text-brand mb-5 text-sm"><i class="<%= col.icon %>"></i> <%= col.title %></h3>
        <div class="flex flex-col divide-y divide-white/[0.04]">
          <% col.items.forEach(s=>{ %>
          <div class="flex items-center justify-between py-2.5">
            <span class="text-sm font-medium text-gray-200"><%= s.name %></span>
            <%
              const labelClass = s.label === 'Avanzado'
                ? 'bg-green-500/10 text-green-400 border-green-500/25'
                : s.label === 'Medio'
                ? 'bg-brand/10 text-brand border-brand/25'
                : 'bg-orange-500/10 text-orange-400 border-orange-500/25';
            %>
            <span class="text-[11px] font-bold px-3 py-0.5 rounded-full border <%= labelClass %>"><%= s.label %></span>
          </div>
          <% }) %>
        </div>
      </div>
      <% }) %>
    </div>

    <!-- Tech Categories -->
    <div class="text-center mb-10 reveal">
      <span class="inline-block px-4 py-1 rounded-full text-xs font-semibold text-brand bg-brand/10 border border-brand/25 tracking-wide mb-3">🛠️ Herramientas y Categorías</span>
      <h2 class="text-3xl font-black">Tech <span class="text-gradient">Stack</span></h2>
    </div>
    <div class="reveal grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-4">
      <% skills.categories.forEach(cat=>{ %>
      <div class="p-4 bg-dark-700 border border-white/[0.06] rounded-2xl hover:border-brand/30 hover:-translate-y-1.5 hover:shadow-glow transition-all">
        <div class="text-2xl mb-2"><%= cat.icon %></div>
        <h3 class="font-bold text-xs text-white mb-2.5"><%= cat.title %></h3>
        <div class="flex flex-wrap gap-1">
          <% cat.items.forEach(item=>{ %>
          <span class="text-[10px] px-2 py-0.5 rounded-md bg-white/[0.04] border border-white/[0.06] text-gray-400"><%= item %></span>
          <% }) %>
        </div>
      </div>
      <% }) %>
    </div>

  </div>
</section>

<%- include('partials/foot') %>
