<%- include('partials/head') %>

  <!-- Page Hero -->
  <section class="relative pt-28 pb-16 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <div class="orb w-96 h-96 -top-20 -right-20 bg-brand/25"></div>
      <div class="orb w-64 h-64 bottom-0 -left-10 bg-cyan/15" style="animation-delay:-3s"></div>
    </div>
    <div class="relative z-10 max-w-6xl mx-auto px-6 text-center reveal">
      <span
        class="inline-block px-4 py-1 rounded-full text-xs font-semibold text-brand bg-brand/10 border border-brand/25 tracking-wide mb-4"><i class="fas fa-user mr-1"></i>
        Conóceme</span>
      <h1 class="text-5xl font-black mb-3">Sobre <span class="text-gradient">Mí</span></h1>
      <p class="text-gray-400 text-lg">Desarrollador Backend con pasión por construir APIs robustas y escalables</p>
    </div>
  </section>

  <!-- About Grid -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-[1fr_1.6fr] gap-14 items-start">

        <!-- Visual side -->
        <div class="reveal flex flex-col items-center gap-6">
          <!-- Avatar -->
          <div class="relative w-44 h-44 shrink-0">
            <img src="/images/profile.jpg" alt="Dixson Apaza"
              class="w-44 h-44 rounded-full object-cover object-top border-4 border-brand/40 shadow-glow" />
            <div class="avatar-ring absolute border border-brand/40" style="inset:-12px"></div>
            <div class="avatar-ring absolute border border-brand/20" style="inset:-24px;animation-delay:.5s"></div>
            <div class="avatar-ring absolute border border-brand/10" style="inset:-36px;animation-delay:1s"></div>
          </div>
          <div class="flex items-center gap-2 text-sm text-gray-400">
            <span class="w-2 h-2 rounded-full bg-green-400 pulse-dot"></span> Disponible para trabajar
          </div>

          <div class="w-full flex flex-col gap-2.5">
            <% [['fas fa-map-marker-alt','Ubicación','Arequipa, Perú'],['fas fa-envelope','Email','dixson.apaza@tecsup.edu.pe'],['fas fa-phone','Teléfono','+51 955724530'],['fas fa-code','Nivel','Junior Developer']].forEach(([icon,label,val])=>{ %>
            <div class="flex items-center gap-3 p-3 bg-dark-700 border border-white/[0.06] rounded-xl hover:border-brand/30 transition-colors">
              <i class="<%= icon %> text-brand w-4 text-center shrink-0"></i>
              <div>
                <span class="block text-[10px] text-gray-500 uppercase tracking-widest"><%= label %></span>
                <span class="text-sm font-medium text-white break-all"><%= val %></span>
              </div>
            </div>
            <% }) %>
          </div>
        </div>

        <!-- Text side -->
        <div class="reveal">
          <h2 class="text-3xl font-black mb-2">Backend Developer Jr</h2>
          <p class="text-gradient text-lg font-semibold mb-5">APIs REST | Django | Node.js</p>
          <p class="text-gray-400 leading-relaxed mb-7">
            <%= profile.bio %>
          </p>

          <h3 class="font-bold mb-3 text-white">¿Qué me hace diferente?</h3>
          <ul class="flex flex-col gap-2.5 mb-8">
            <% profile.highlights.forEach(h=>{ %>
              <li class="flex items-start gap-3 text-sm text-gray-400">
                <i class="fas fa-check-circle text-green-400 mt-0.5 shrink-0"></i>
                <%= h %>
              </li>
              <% }) %>
          </ul>

          <div class="flex flex-wrap gap-3">
            <a href="/proyectos"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-white bg-gradient-hero hover:shadow-glow hover:-translate-y-0.5 transition-all"><i
                class="fas fa-rocket"></i> Ver Proyectos</a>
            <a href="/contactame"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-brand border border-brand hover:bg-brand hover:text-white transition-all"><i
                class="fas fa-paper-plane"></i> Contáctame</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="py-20 bg-dark-800 border-y border-white/[0.06]">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-12 reveal">
        <span
          class="inline-block px-4 py-1 rounded-full text-xs font-semibold text-brand bg-brand/10 border border-brand/25 tracking-wide mb-3"><i class="fas fa-lightbulb mr-1"></i>
          Mi Filosofía</span>
        <h2 class="text-3xl font-black">Lo que me <span class="text-gradient">impulsa</span></h2>
      </div>
      <div class="reveal grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        <% [['fas fa-bullseye','Orientado a Resultados','Cada línea de código tiene un propósito. Me enfoco en entregar soluciones que generen impacto real.'],['fas fa-search','Resolución de Problemas','Analizo los desafíos técnicos desde múltiples ángulos para encontrar la solución más eficiente.'],['fas fa-book-reader','Aprendizaje Continuo','La tecnología evoluciona constantemente. Me mantengo actualizado con las últimas tendencias.'],['fas fa-robot','IA como Herramienta','Uso inteligentemente el potencial de la IA para maximizar la productividad y calidad del código.']].forEach(([icon,title,desc])=>{ %>
        <div class="p-6 bg-dark-700 border border-white/[0.06] rounded-2xl text-center hover:border-brand/30 hover:-translate-y-1.5 hover:shadow-glow transition-all">
          <div class="text-3xl text-white mb-4 flex justify-center"><i class="<%= icon %>"></i></div>
          <h3 class="font-bold mb-2 text-sm"><%= title %></h3>
          <p class="text-xs text-gray-400 leading-relaxed"><%= desc %></p>
        </div>
        <% }) %>
      </div>
      </div>
    </div>
  </section>

  <%- include('partials/foot') %>