    <li><a href="/proyectos" class="flex items-center gap-3 px-4 py-3.5 rounded-xl text-lg font-medium text-gray-300 hover:text-white hover:bg-brand/10 transition-all"><i class="fas fa-rocket w-5 text-center text-brand"></i> Proyectos</a></li>
    <li><a href="/contactame" class="flex items-center gap-3 px-4 py-3.5 rounded-xl text-lg font-semibold bg-gradient-hero text-white transition-all"><i class="fas fa-envelope w-5 text-center"></i> Contáctame</a></li>
