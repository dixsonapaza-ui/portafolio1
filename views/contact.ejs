<%- include('partials/head') %>

<!-- Page Hero -->
<section class="relative pt-28 pb-16 overflow-hidden">
  <div class="absolute inset-0 z-0">
    <div class="orb w-96 h-96 -top-20 -right-20 bg-brand/25"></div>
    <div class="orb w-64 h-64 bottom-0 -left-10 bg-cyan/15" style="animation-delay:-3s"></div>
  </div>
  <div class="relative z-10 max-w-6xl mx-auto px-6 text-center reveal">
    <span class="inline-block px-4 py-1 rounded-full text-xs font-semibold text-brand bg-brand/10 border border-brand/25 tracking-wide mb-4">📬 Hablemos</span>
    <h1 class="text-5xl font-black mb-3">Contácta<span class="text-gradient">me</span></h1>
    <p class="text-gray-400 text-lg">¿Tienes un proyecto, oportunidad o simplemente quieres saludar? Escríbeme.</p>
  </div>
</section>

<section class="py-16">
  <div class="max-w-5xl mx-auto px-6">
    <div class="grid lg:grid-cols-[1fr_1.4fr] gap-12 items-start">

      <!-- Info -->
      <div class="reveal">
        <h2 class="text-3xl font-black mb-2">¡Trabajemos <span class="text-gradient">juntos!</span></h2>
        <p class="text-gray-400 leading-relaxed mb-8">Estoy en búsqueda activa de nuevas oportunidades como Backend Developer Jr. Si tienes un proyecto interesante o una vacante, me encantaría conversar.</p>

        <div class="flex flex-col gap-4 mb-8">
          <div class="flex items-center gap-4">
            <div class="w-11 h-11 shrink-0 rounded-xl bg-brand/10 border border-brand/25 flex items-center justify-center text-brand"><i class="fas fa-envelope"></i></div>
            <div>
              <span class="block text-[10px] text-gray-500 uppercase tracking-widest">Email</span>
              <a href="mailto:<%= profile.email %>" class="text-sm font-medium text-white hover:text-brand transition-colors"><%= profile.email %></a>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-11 h-11 shrink-0 rounded-xl bg-brand/10 border border-brand/25 flex items-center justify-center text-brand"><i class="fas fa-phone"></i></div>
            <div>
              <span class="block text-[10px] text-gray-500 uppercase tracking-widest">Teléfono</span>
              <a href="tel:<%= profile.phone %>" class="text-sm font-medium text-white hover:text-brand transition-colors"><%= profile.phone %></a>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="w-11 h-11 shrink-0 rounded-xl bg-brand/10 border border-brand/25 flex items-center justify-center text-brand"><i class="fas fa-map-marker-alt"></i></div>
            <div>
              <span class="block text-[10px] text-gray-500 uppercase tracking-widest">Ubicación</span>
              <span class="text-sm font-medium text-white"><%= profile.location %></span>
            </div>
          </div>
        </div>

        <div class="flex gap-2">
          <a href="mailto:<%= profile.email %>" class="flex flex-col items-center gap-1 px-5 py-3 bg-dark-700 border border-white/[0.06] rounded-xl text-gray-400 text-xs hover:text-brand hover:border-brand/40 hover:-translate-y-0.5 transition-all"><i class="fas fa-envelope text-lg"></i>Email</a>
          <a href="<%= profile.linkedin %>" target="_blank" class="flex flex-col items-center gap-1 px-5 py-3 bg-dark-700 border border-white/[0.06] rounded-xl text-gray-400 text-xs hover:text-brand hover:border-brand/40 hover:-translate-y-0.5 transition-all"><i class="fab fa-linkedin text-lg"></i>LinkedIn</a>
          <a href="<%= profile.github %>" target="_blank" class="flex flex-col items-center gap-1 px-5 py-3 bg-dark-700 border border-white/[0.06] rounded-xl text-gray-400 text-xs hover:text-brand hover:border-brand/40 hover:-translate-y-0.5 transition-all"><i class="fab fa-github text-lg"></i>GitHub</a>
        </div>
      </div>

      <!-- Form -->
      <div class="reveal p-8 bg-dark-700 border border-white/[0.06] rounded-3xl">
        <% if (locals.error) { %>
        <div class="mb-4 p-4 rounded-xl bg-red-500/10 border border-red-500/30 text-red-400 text-sm flex items-center gap-2">
          <i class="fas fa-exclamation-triangle"></i> <%= error %>
        </div>
        <% } %>

        <form action="/contactame" method="POST" class="flex flex-col gap-5" id="contactForm">
          <div>
            <label for="name" class="block text-sm font-semibold mb-2">Nombre completo</label>
            <div class="relative">
              <i class="fas fa-user absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-500 text-sm"></i>
              <input type="text" id="name" name="name" required placeholder="Tu nombre"
                class="w-full pl-10 pr-4 py-3 bg-dark-900 border border-white/[0.08] rounded-xl text-sm text-white placeholder-gray-600 focus:outline-none focus:border-brand/60 focus:ring-2 focus:ring-brand/10 transition-all" />
            </div>
          </div>

          <div>
            <label for="email" class="block text-sm font-semibold mb-2">Correo electrónico</label>
            <div class="relative">
              <i class="fas fa-envelope absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-500 text-sm"></i>
              <input type="email" id="email" name="email" required placeholder="tucorreo@email.com"
                class="w-full pl-10 pr-4 py-3 bg-dark-900 border border-white/[0.08] rounded-xl text-sm text-white placeholder-gray-600 focus:outline-none focus:border-brand/60 focus:ring-2 focus:ring-brand/10 transition-all" />
            </div>
          </div>

          <div>
            <label for="subject" class="block text-sm font-semibold mb-2">Asunto</label>
            <div class="relative">
              <i class="fas fa-tag absolute left-3.5 top-1/2 -translate-y-1/2 text-gray-500 text-sm"></i>
              <input type="text" id="subject" name="subject" required placeholder="¿De qué quieres hablar?"
                class="w-full pl-10 pr-4 py-3 bg-dark-900 border border-white/[0.08] rounded-xl text-sm text-white placeholder-gray-600 focus:outline-none focus:border-brand/60 focus:ring-2 focus:ring-brand/10 transition-all" />
            </div>
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold mb-2">Mensaje</label>
            <textarea id="message" name="message" required rows="5" placeholder="Cuéntame sobre tu proyecto o consulta..."
              class="w-full px-4 py-3 bg-dark-900 border border-white/[0.08] rounded-xl text-sm text-white placeholder-gray-600 focus:outline-none focus:border-brand/60 focus:ring-2 focus:ring-brand/10 transition-all resize-y min-h-[120px]"></textarea>
          </div>

          <button type="submit" id="submitBtn"
            class="w-full flex items-center justify-center gap-2 py-3.5 rounded-xl font-semibold text-white bg-gradient-hero hover:shadow-glow hover:-translate-y-0.5 transition-all">
            <i class="fas fa-paper-plane"></i>
            <span>Enviar Mensaje</span>
          </button>
        </form>
      </div>
    </div>
  </div>
</section>

<%- include('partials/foot') %>
