<%- include('partials/head') %>

<div class="contact-container">
  <div class="contact-header">
    <h1 class="contact-title fr-display">Contáctame</h1>
    <p class="contact-subtitle">¿Tienes un proyecto, oportunidad o simplemente quieres conversar? Escríbeme.</p>
  </div>

  <div class="contact-grid">
    <!-- Info Column -->
    <div class="contact-info-card">
      <div class="info-item">
        <div class="info-icon"><i class="fas fa-envelope"></i></div>
        <div>
          <span class="info-label">Email</span>
          <p><a href="mailto:<%= profile.email %>" class="info-value"><%= profile.email %></a></p>
        </div>
      </div>

      <div class="info-item">
        <div class="info-icon"><i class="fas fa-phone"></i></div>
        <div>
          <span class="info-label">Teléfono</span>
          <p><a href="tel:<%= profile.phone %>" class="info-value"><%= profile.phone %></a></p>
        </div>
      </div>

      <div class="info-item">
        <div class="info-icon"><i class="fas fa-map-marker-alt"></i></div>
        <div>
          <span class="info-label">Ubicación</span>
          <p class="info-value"><%= profile.location %></p>
        </div>
      </div>

      <div class="info-item" style="margin-top: 20px;">
        <div style="display: flex; gap: 12px;">
          <a href="<%= profile.linkedin %>" target="_blank" class="info-icon" style="text-decoration: none;" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
          <a href="<%= profile.github %>" target="_blank" class="info-icon" style="text-decoration: none;" aria-label="GitHub"><i class="fab fa-github"></i></a>
          <a href="<%= profile.instagram %>" target="_blank" class="info-icon" style="text-decoration: none;" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
          <a href="<%= profile.whatsapp %>" target="_blank" class="info-icon" style="text-decoration: none;" aria-label="WhatsApp"><i class="fab fa-whatsapp"></i></a>
        </div>
      </div>
    </div>

    <!-- Form Column -->
    <div class="contact-form-card">
      <% if (locals.error) { %>
        <div style="background: rgba(232, 98, 26, 0.1); border: 1px solid var(--accent-1); color: var(--text-primary); padding: 16px; border-radius: 8px; margin-bottom: 24px; font-size: 14px;">
          <i class="fas fa-exclamation-triangle" style="margin-right: 8px;"></i> <%= error %>
        </div>
      <% } %>

      <form action="/contactame" method="POST" id="contactForm">
        <div class="form-group">
          <label for="name" class="form-label">Nombre Completo</label>
          <input type="text" id="name" name="name" required placeholder="Tu nombre" class="form-input" />
        </div>

        <div class="form-group">
          <label for="email" class="form-label">Correo Electrónico</label>
          <input type="email" id="email" name="email" required placeholder="tucorreo@email.com" class="form-input" />
        </div>

        <div class="form-group">
          <label for="subject" class="form-label">Asunto</label>
          <input type="text" id="subject" name="subject" required placeholder="¿De qué quieres hablar?" class="form-input" />
        </div>

        <div class="form-group">
          <label for="message" class="form-label">Mensaje</label>
          <textarea id="message" name="message" required rows="5" placeholder="Cuéntame sobre tu proyecto o consulta..." class="form-textarea"></textarea>
        </div>

        <button type="submit" id="submitBtn" class="btn-submit">
          <i class="fas fa-paper-plane"></i>
          <span>Enviar Mensaje</span>
        </button>
      </form>
    </div>
  </div>
</div>

<%- include('partials/foot') %>
