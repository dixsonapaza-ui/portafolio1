<%- include('partials/head') %>

  <!-- Hero Section -->
  <section class="hero">
    <svg class="water-defs" width="0" height="0" aria-hidden="true" focusable="false">
      <filter id="water-distort" x="-10%" y="-10%" width="120%" height="120%">
        <feTurbulence type="turbulence" baseFrequency="0.014 0.038" numOctaves="2" seed="3" result="turb">
          <animate attributeName="baseFrequency" dur="16s" values="0.014 0.038;0.018 0.044;0.013 0.036;0.014 0.038" repeatCount="indefinite"></animate>
        </feTurbulence>
        <feDisplacementMap in="SourceGraphic" in2="turb" scale="14" xChannelSelector="R" yChannelSelector="G"></feDisplacementMap>
      </filter>
    </svg>
    <video class="hero-video" autoplay loop muted playsinline poster="/images/hero.png" onerror="this.style.display='none'">
      <source src="/images/minimalist.mp4" type="video/mp4">
    </video>
    <div class="hero-overlay"></div>
    <div class="hero-right-meta">QA Testing · Cypress · REST APIs · Full Stack</div>
    <div class="hero-meta">
      <p class="hero-eyebrow">QA Tester Junior | Full Stack Developer</p>
      <h1 class="hero-headline">
        <span class="hero-word">Dixson</span>
        <span class="hero-word">Yonay</span>
        <span class="hero-word">Apaza</span>
        <span class="hero-word">Quilla</span>
      </h1>
      <p class="hero-sub"><%= profile.bio %></p>
      <a class="hero-cta" href="#work">Ver Proyectos <span class="hero-cta-arrow">→</span></a>
    </div>
    <div class="hero-coord">16.4°S / 71.5°W · Arequipa, Perú</div>
  </section>

  <!-- Projects Section (Sticky Stacking Panels) -->
  <section class="stack-section" id="work">
    <div class="stack-wrapper" id="stack-wrapper">
      <div class="stack-pin">
        <div class="stack-counter"><span class="current" id="stack-current">01</span>/ 03 — Proyectos Destacados</div>

        <% projects.forEach((p, idx) => { %>
          <div class="stack-panel" data-tone="<%= (idx % 3) + 1 %>" data-side="<%= idx % 2 === 0 ? 'left' : 'right' %>" data-idx="<%= idx %>">
            <div class="stack-inner">
              <div class="stack-img">
                <img src="<%= p.image %>" alt="<%= p.title %>" loading="lazy" onerror="this.style.display='none'">
              </div>
              <div class="stack-text">
                <p class="stack-eyebrow">Proyecto · <%= p.year %></p>
                <p class="stack-index">№ 0<%= idx + 1 %> / 03</p>
                <h2 class="stack-title"><%= p.title %></h2>
                <p class="stack-cat"><%= p.cat %></p>
                <p class="stack-desc"><%= p.description %></p>
                <ul class="stack-bullets">
                  <% p.bullets.forEach(bullet => { %>
                    <li><%= bullet %></li>
                  <% }) %>
                </ul>
                <a href="<%= p.link %>" target="_blank" class="stack-link">Visitar Proyecto →</a>
              </div>
            </div>
          </div>
        <% }) %>

      </div>
    </div>
  </section>

  <!-- About, Skills & Education (Pinned Split Text Swap) -->
  <section class="split-section" id="about">
    <div class="split-pin">
      <div class="split-visuals" id="split-visuals">
        <div class="split-counter">
          <span class="current" id="split-current">01</span><span class="total">/03</span>
        </div>
        <img src="/images/YOconTernito.jpg" alt="Dixson Apaza" class="split-img active" data-idx="0">
        <img src="/images/skills.png" alt="Habilidades" class="split-img" data-idx="1">
        <img src="/images/education-stack.png" alt="Educación" class="split-img" data-idx="2">
      </div>
      <div class="split-text-wrap">
        <p class="split-section-label">Sobre Mí &amp; Habilidades · 3 Capítulos</p>
        <div class="split-panels">

          <!-- Panel 1: Profile -->
          <div class="split-panel active" data-idx="0">
            <p class="split-eyebrow">Capítulo · 01</p>
            <h3 class="split-title">Desarrollador Backend.</h3>
            <p class="split-desc"><%= profile.bio %></p>
            <ul class="split-deliverables">
              <% profile.highlights.forEach(highlight => { %>
                <li><%= highlight %></li>
              <% }) %>
            </ul>
            <div class="cv-download-group">
              <a href="/cv-preview/fullstack" class="cv-btn" target="_blank"><i class="fas fa-file-download"></i> CV Full Stack</a>
              <a href="/cv-preview/qatester" class="cv-btn secondary" target="_blank"><i class="fas fa-file-download"></i> CV QA Tester</a>
            </div>
          </div>

          <!-- Panel 2: Skills -->
          <div class="split-panel" data-idx="1">
            <p class="split-eyebrow">Capítulo · 02</p>
            <h3 class="split-title">Habilidades Técnicas.</h3>
            <p class="split-desc">Domino un ecosistema moderno para el desarrollo de APIs robustas, integrando lenguajes, frameworks y bases de datos eficientes.</p>
            
            <div class="split-skills-grid">
              <div class="split-skill-item">
                <i class="fab fa-python"></i>
                <span>Python / Django</span>
              </div>
              <div class="split-skill-item">
                <i class="fab fa-node-js"></i>
                <span>Node.js / Express</span>
              </div>
              <div class="split-skill-item">
                <i class="fas fa-database"></i>
                <span>SQL / MySQL / SQLite</span>
              </div>
              <div class="split-skill-item">
                <i class="fab fa-git-alt"></i>
                <span>Git / GitHub / CI-CD</span>
              </div>
            </div>

            <ul class="split-deliverables">
              <li>Frameworks: Django, Express, Laravel</li>
              <li>Bases de datos: MySQL, SQLite, PostgreSQL</li>
              <li>Testing: Postman, k6 (Load Testing)</li>
            </ul>
          </div>

          <!-- Panel 3: Education -->
          <div class="split-panel" data-idx="2">
            <p class="split-eyebrow">Capítulo · 03</p>
            <h3 class="split-title">Educación y Formación.</h3>
            <% education.forEach(edu => { %>
              <p class="split-desc"><strong><%= edu.institution %></strong> — <%= edu.degree %> (<%= edu.period %>). <%= edu.description %></p>
              <ul class="split-deliverables">
                <% edu.highlights.forEach(hl => { %>
                  <li><%= hl %></li>
                <% }) %>
              </ul>
            <% }) %>
          </div>

        </div>
        <div class="split-progress">
          <div class="split-progress-dot active" data-idx="0"></div>
          <div class="split-progress-dot" data-idx="1"></div>
          <div class="split-progress-dot" data-idx="2"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Experience Section (Cursor-Tracked List Preview) -->
  <section class="cursor-section" id="experience">
    <div class="cursor-section-header">
      <p class="cursor-eyebrow">Proyectos & Experiencia · 2024 — Presente</p>
      <h2 class="cursor-heading">Trayectoria laboral y<br>proyectos desarrollados.</h2>
    </div>
    <ul class="cursor-list" id="cursor-list">
      <% experience.forEach((exp, idx) => { %>
        <li class="cursor-item" data-img="<%= exp.image %>" data-href="#experience-details" data-idx="<%= idx %>">
          <span class="cursor-num">/ 0<%= idx + 1 %></span>
          <span class="cursor-name"><%= exp.company %></span>
          <span class="cursor-year"><%= exp.role %> · <%= exp.period %></span>
        </li>
      <% }) %>
    </ul>
    <div class="cursor-preview" id="cursor-preview">
      <img id="cursor-preview-img" alt="">
    </div>
    <div class="cursor-dot" id="cursor-dot"></div>
  </section>

<%- include('partials/foot') %>
