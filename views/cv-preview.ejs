<%- include('partials/head') %>

<section style="min-height: 100vh; padding: 140px 24px 80px; background: var(--bg-primary);">
  <div style="max-width: 1000px; width: 100%; margin: 0 auto;">
    
    <!-- Top Action Bar -->
    <div style="display: flex; justify-content: space-between; align-items: center; background: var(--bg-secondary); border: 1px solid rgba(255, 255, 255, 0.05); padding: 20px 32px; border-radius: 16px; margin-bottom: 24px; flex-wrap: wrap; gap: 16px; box-shadow: var(--shadow-premium);">
      <div>
        <a href="/" style="font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); text-decoration: none; text-transform: uppercase; letter-spacing: 0.1em; display: inline-flex; align-items: center; gap: 6px; transition: color 0.3s;" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='var(--text-muted)'">
          <i class="fas fa-arrow-left"></i> Volver al Portafolio
        </a>
        <h1 style="font-family: var(--font-body); font-size: 20px; font-weight: 600; color: #fff; margin: 8px 0 0;">
          Vista Previa: CV <%= type === 'fullstack' ? 'Full Stack Developer' : 'QA Tester' %>
        </h1>
      </div>

      <% if (exists) { %>
        <div>
          <a href="/descargar-cv/<%= type %>?download=true" class="cv-btn" style="padding: 12px 24px; display: inline-flex; align-items: center; gap: 8px; text-decoration: none;">
            <i class="fas fa-download"></i> Descargar CV
          </a>
        </div>
      <% } %>
    </div>

    <!-- Main Content Area -->
    <div style="background: var(--bg-secondary); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 20px; min-height: 700px; display: flex; flex-direction: column; overflow: hidden; box-shadow: var(--shadow-premium);">
      
      <% if (!exists) { %>
        <!-- Case 1: CV does not exist -->
        <div style="flex-grow: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 48px; text-align: center;">
          <div style="width: 80px; height: 80px; border-radius: 50%; background: rgba(232, 98, 26, 0.1); border: 1px solid rgba(232, 98, 26, 0.2); display: flex; align-items: center; justify-content: center; margin-bottom: 24px;">
            <i class="fas fa-file-excel" style="font-size: 32px; color: var(--accent-1);"></i>
          </div>
          <h2 style="font-family: var(--font-body); font-size: 24px; color: #fff; margin: 0 0 12px;">CV No Disponible</h2>
          <p style="font-family: var(--font-body); font-size: 15px; color: var(--text-muted); max-width: 460px; margin: 0 auto 24px; line-height: 1.6;">
            Aún no se ha subido la versión más reciente de este currículum. Si necesitas mi perfil para una vacante, puedes contactarme directamente.
          </p>
          <a href="/#contact" class="cv-btn" style="text-decoration: none;">Contáctame</a>
        </div>
      <% } else if (ext === 'pdf') { %>
        <!-- Case 2: PDF Preview (Embedded Viewer) -->
        <div style="flex-grow: 1; position: relative; height: 750px;">
          <iframe src="/descargar-cv/<%= type %>" width="100%" height="100%" style="border: none; background: #fff;" title="Vista Previa de CV"></iframe>
        </div>
      <% } else { %>
        <!-- Case 3: DOC / DOCX Preview (Word placeholder with direct download) -->
        <div style="flex-grow: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 48px; text-align: center;">
          <div style="width: 80px; height: 80px; border-radius: 50%; background: rgba(255, 255, 255, 0.03); border: 1px solid rgba(255, 255, 255, 0.06); display: flex; align-items: center; justify-content: center; margin-bottom: 24px;">
            <i class="fas fa-file-word" style="font-size: 36px; color: #4b86e7;"></i>
          </div>
          <h2 style="font-family: var(--font-body); font-size: 24px; color: #fff; margin: 0 0 12px;">Documento de Word</h2>
          <p style="font-family: var(--font-body); font-size: 15px; color: var(--text-muted); max-width: 500px; margin: 0 auto 24px; line-height: 1.6;">
            El archivo está en formato <strong>.<%= ext.toUpperCase() %></strong>. Los navegadores no permiten visualizar archivos Word directamente. Puedes descargarlo haciendo clic en el botón de abajo.
          </p>
          
          <div style="background: var(--bg-primary); border-radius: 12px; padding: 16px 24px; margin-bottom: 32px; display: inline-block; text-align: left; border: 1px solid rgba(255,255,255,0.03);">
            <div style="font-family: var(--font-mono); font-size: 12px; color: var(--text-muted); line-height: 1.8;">
              <div><strong style="color:#fff;">Nombre:</strong> CV_Dixson_Apaza_<%= type === 'fullstack' ? 'FullStack' : 'QATester' %>.<%= ext %></div>
              <div><strong style="color:#fff;">Tamaño:</strong> <%= (size / (1024 * 1024)).toFixed(2) %> MB</div>
              <div><strong style="color:#fff;">Última edición:</strong> <%= new Date(mtime).toLocaleDateString('es-PE') %></div>
            </div>
          </div>
          
          <a href="/descargar-cv/<%= type %>?download=true" class="cv-btn" style="text-decoration: none; padding: 14px 32px; font-size: 12px;">
            <i class="fas fa-download"></i> Descargar Documento
          </a>
        </div>
      <% } %>

    </div>

  </div>
</section>

<%- include('partials/foot') %>
